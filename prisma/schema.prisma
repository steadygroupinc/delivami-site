// landing-page/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id          String   @id @default(cuid())
  email       String   @unique
  creatorType String
  region      String?
  createdAt   DateTime @default(now())
}
